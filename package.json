{
  "name": "healthsync-cloud",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "HealthSync Cloud — multi-tenant SaaS build. Stage 1: tenancy foundation.",
  "scripts": {
    "provision": "node --env-file=.env scripts/provision.mjs",
    "migrate": "node --env-file=.env scripts/migrate.mjs",
    "etl:dry": "node --env-file=.env scripts/etl-casa-elev8.mjs",
    "etl:apply": "node --env-file=.env scripts/etl-casa-elev8.mjs --apply",
    "test:tenant-isolation": "node --env-file=.env scripts/test-tenant-isolation.mjs",
    "setup": "npm run provision && npm run etl:apply && npm run test:tenant-isolation"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "pg": "^8.13.0"
  }
}
